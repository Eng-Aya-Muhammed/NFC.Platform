## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Original source: https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
*.pidb
*.resources
*.csproj.user
*.csproj.vspscc
*.sln.vspscc
*.slnx.user

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leases/
x64/
x86/
build/
bin/
obj/
[Ms][Bb]uild/
submodules/

# Visual Studio 2015/2017/2019/2022 cache directory
.vs/
# Generated user files in solution
*.slnx.user

# Web Server caches
.ehc/

# dotnet tools local folder
.dotnet/

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Rider / IntelliJ
.idea/

# Diagnostics
*.gps
*.gpState

# Publish output
/Publish/
/publish/

# Local logs
[Ll]ogs/
*.log

# Windows image analyses
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Crash dumps
*.dmp
*.dump

# SQL Server files
*.mdf
*.ldf
*.ndf

# Rider
*.sln.iml

# dotnet user-secrets
secrets.json

# Local environment secrets
.env
.env.*

